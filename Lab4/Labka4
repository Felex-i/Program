Задача 2.3: Классификация символов
Постановка задачи
Классифицировать каждый символ строки с помощью функций из ctype.h (isdigit, isalpha, isspace, ispunct).

Список идентификаторов
Имя	Тип	Описание
isdigit	function	Проверка на цифру
isalpha	function	Проверка на букву
isspace	function	Проверка на пробел
ispunct	function	Проверка на пунктуацию
Код программы
c
#include <stdio.h>
#include <ctype.h>

int main(void) {
    char test_str[] = "A7, b9! \t";
    printf("Анализ строки: \"%s\"\n\n", test_str);
    
    for (int i = 0; test_str[i] != '\0'; i++) {
        unsigned char c = (unsigned char)test_str[i];
        printf("'%c' (код %d): ", (c >= 32 && c <= 126) ? c : '?', c);
        
        int first = 1;
        if (isdigit(c)) { printf("цифра"); first = 0; }
        if (isalpha(c)) { printf("%sбуква", first ? "" : ", "); first = 0; }
        if (isspace(c)) { printf("%sпробел", first ? "" : ", "); first = 0; }
        if (ispunct(c)) { printf("%sпунктуация", first ? "" : ", "); first = 0; }
        if (first) printf("другой");
        printf("\n");
    }
    
    return 0;
}
