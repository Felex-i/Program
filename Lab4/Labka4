#include <stdio.h>
#include <string.h>
#include <ctype.h>

int main(void) {
    #define MY_SIZE 32
    char my_string[MY_SIZE] = "HelloC";
    
    // Шаг 1. Ручной подсчёт по индексам
    int len1 = 0;
    for (int i = 0; my_string[i] != '\0'; i++) len1++;
    printf("По индексам: %d\n", len1);
    
    // Шаг 2. Ручной подсчёт по указателю
    char *p = my_string;
    int len2 = 0;
    while (*p != '\0') { len2++; p++; }
    printf("По указателю: %d\n", len2);
    
    // Шаг 3. Библиотечная функция
    size_t len3 = strlen(my_string);
    printf("strlen: %zu\n", len3);
    
    // Шаг 4. Копирование
    char copy[MY_SIZE];
    for (int i = 0; i <= len1; i++) copy[i] = my_string[i];
    printf("Копия: \"%s\"\n", copy);
    
    // Шаг 5. Конкатенация
    char str1[] = "Hello", str2[] = "World", concat[MY_SIZE * 2];
    int idx = 0;
    for (int i = 0; str1[i]; i++) concat[idx++] = str1[i];
    for (int i = 0; str2[i]; i++) concat[idx++] = str2[i];
    concat[idx] = '\0';
    printf("Конкатенация: \"%s\"\n", concat);
    
    // Шаг 6. Сравнение
    char cmp1[] = "apple", cmp2[] = "banana";
    int cmp = strcmp(cmp1, cmp2);
    printf("Сравнение \"%s\" и \"%s\": %d\n", cmp1, cmp2, cmp);
    
    // Шаг 7. Перевод регистра
    char mixed[] = "HeLlO WoRlD! 123";
    char lower[MY_SIZE], upper[MY_SIZE];
    for (int i = 0; mixed[i]; i++) {
        unsigned char uc = (unsigned char)mixed[i];
        lower[i] = tolower(uc);
        upper[i] = toupper(uc);
    }
    lower[strlen(mixed)] = upper[strlen(mixed)] = '\0';
    printf("Нижний: \"%s\"\nВерхний: \"%s\"\n", lower, upper);
    
    return 0;
}
