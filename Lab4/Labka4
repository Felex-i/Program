Задача 1.2: Обмен чётных/нечётных ячеек массива
Постановка задачи
Реализовать функцию, выполняющую попарный обмен соседних элементов массива (индексы 0↔1, 2↔3, ...).

Список идентификаторов
Имя	Тип	Описание
swap_adjacent_pairs	void ()(int, size_t)	Функция обмена соседних пар
print_array	void ()(const int, size_t)	Функция вывода массива
Код программы
c
#include <stdio.h>
#include <stdlib.h>

void swap_adjacent_pairs(int *arr, size_t size) {
    for (size_t i = 0; i + 1 < size; i += 2) {
        int temp = arr[i];
        arr[i] = arr[i + 1];
        arr[i + 1] = temp;
    }
}

void print_array(const int *arr, size_t size) {
    printf("[");
    for (size_t i = 0; i < size; i++) {
        printf("%d%s", arr[i], (i < size - 1) ? ", " : "");
    }
    printf("]");
}

int main(void) {
    size_t size = 12;
    int *arr = malloc(size * sizeof(int));
    
    for (size_t i = 0; i < size; i++) {
        arr[i] = (int)(i + 1);
    }
    
    printf("Исходный массив: ");
    print_array(arr, size);
    printf("\n");
    
    swap_adjacent_pairs(arr, size);
    
    printf("После обмена:    ");
    print_array(arr, size);
    printf("\n");
    
    free(arr);
    return 0;
}
