Задача 2.2: Конвертация строк в числа
Постановка задачи
Безопасно преобразовывать строки в int и double с использованием strtol и strtod, с проверкой ошибок.

Список идентификаторов
Имя	Тип	Описание
strtol	function	Преобразование в long
strtod	function	Преобразование в double
errno	variable	Код ошибки
endptr	char*	Указатель на остаток строки
Код программы
c
#include <stdio.h>
#include <stdlib.h>
#include <errno.h>

int main(void) {
    // Преобразование в целое число
    char int_str[] = "  -42  ";
    errno = 0;
    char *endptr;
    long int_val = strtol(int_str, &endptr, 10);
    
    printf("Целое: \"%s\" -> %ld\n", int_str, int_val);
    if (endptr == int_str)
        printf("  Ошибка: нет цифр\n");
    else if (errno == ERANGE)
        printf("  Ошибка: вне диапазона\n");
    
    // Преобразование в вещественное число
    char double_str[] = "  3.14159  ";
    errno = 0;
    double double_val = strtod(double_str, &endptr);
    
    printf("Вещественное: \"%s\" -> %f\n", double_str, double_val);
    if (endptr == double_str)
        printf("  Ошибка: нет цифр\n");
    else if (errno == ERANGE)
        printf("  Ошибка: вне диапазона\n");
    
    return 0;
}
