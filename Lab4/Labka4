Задача 1.3: Набор функций для матрицы double
Постановка задачи
Реализовать функции выделения, заполнения, печати и освобождения двумерного динамического массива.

Список идентификаторов
Имя	Тип	Описание
matrix_alloc	double** (*)(size_t, size_t)	Выделение памяти
matrix_free	void (*)(double**, size_t)	Освобождение памяти
matrix_fill	void ()(double**, size_t, size_t, const double)	Заполнение
matrix_print	void (*)(double**, size_t, size_t)	Печать
Код программы
c
#include <stdio.h>
#include <stdlib.h>

double** matrix_alloc(size_t rows, size_t cols) {
    double **m = malloc(rows * sizeof(double*));
    if (!m) return NULL;
    
    for (size_t i = 0; i < rows; i++) {
        m[i] = malloc(cols * sizeof(double));
        if (!m[i]) {
            for (size_t j = 0; j < i; j++) free(m[j]);
            free(m);
            return NULL;
        }
    }
    return m;
}

void matrix_free(double **m, size_t rows) {
    if (!m) return;
    for (size_t i = 0; i < rows; i++) free(m[i]);
    free(m);
}

void matrix_fill(double **m, size_t rows, size_t cols, const double *values) {
    for (size_t i = 0; i < rows; i++)
        for (size_t j = 0; j < cols; j++)
            m[i][j] = values[i * cols + j];
}

void matrix_print(double **m, size_t rows, size_t cols) {
    for (size_t i = 0; i < rows; i++) {
        for (size_t j = 0; j < cols; j++)
            printf("%6.2f ", m[i][j]);
        printf("\n");
    }
}

int main(void) {
    size_t rows = 2, cols = 3;
    double values[] = {1, 2, 3, 4, 5, 6};
    
    double **m = matrix_alloc(rows, cols);
    if (!m) return 1;
    
    matrix_fill(m, rows, cols, values);
    printf("Матрица %zux%zu:\n", rows, cols);
    matrix_print(m, rows, cols);
    
    matrix_free(m, rows);
    return 0;
}
