Задача 1.4: Смешанное произведение трёх векторов в 3D
Постановка задачи
Вычислить смешанное произведение трёх векторов через скалярное и векторное произведения.

Математическая модель
Векторное произведение: b × c = (b_y·c_z - b_z·c_y, b_z·c_x - b_x·c_z, b_x·c_y - b_y·c_x)

Скалярное произведение: a·b = a_x·b_x + a_y·b_y + a_z·b_z

Смешанное произведение: [a, b, c] = a·(b×c)

Список идентификаторов
Имя	Тип	Описание
cross3	void (*)(const double[3], const double[3], double[3])	Векторное произведение
dot3	double (*)(const double[3], const double[3])	Скалярное произведение
triple3	double (*)(const double[3], const double[3], const double[3])	Смешанное произведение
Код программы
c
#include <stdio.h>

void cross3(const double a[3], const double b[3], double out[3]) {
    out[0] = a[1] * b[2] - a[2] * b[1];
    out[1] = a[2] * b[0] - a[0] * b[2];
    out[2] = a[0] * b[1] - a[1] * b[0];
}

double dot3(const double a[3], const double b[3]) {
    return a[0] * b[0] + a[1] * b[1] + a[2] * b[2];
}

double triple3(const double a[3], const double b[3], const double c[3]) {
    double tmp[3];
    cross3(b, c, tmp);
    return dot3(a, tmp);
}

void print_vector(const char *name, const double v[3]) {
    printf("%s = (%.2f, %.2f, %.2f)\n", name, v[0], v[1], v[2]);
}

int main(void) {
    double a[3] = {1, 0, 0};
    double b[3] = {0, 1, 0};
    double c[3] = {0, 0, 1};
    
    print_vector("a", a);
    print_vector("b", b);
    print_vector("c", c);
    
    double cross_ab[3];
    cross3(a, b, cross_ab);
    printf("a × b = (%.2f, %.2f, %.2f)\n", cross_ab[0], cross_ab[1], cross_ab[2]);
    
    printf("a · b = %.2f\n", dot3(a, b));
    printf("Смешанное произведение [a, b, c] = %.2f\n", triple3(a, b, c));
    
    return 0;
}
Результаты выполненной работы
text
a = (1.00, 0.00, 0.00)
b = (0.00, 1.00, 0.00)
c = (0.00, 0.00, 1.00)
a × b = (0.00, 0.00, 1.00)
a · b = 0.00
Смешанное произведение [a, b, c] = 1.00
